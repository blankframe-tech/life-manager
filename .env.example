# Copy this file to `.env` (git-ignored) and fill in your Supabase values.
# Get them from the Supabase dashboard: Project Settings → API.
#   SUPABASE_URL       = the "Project URL"   (e.g. https://abcd1234.supabase.co)
#   SUPABASE_ANON_KEY  = the "anon public" key (a long token starting with eyJ...)
# Then run ./run.ps1 (Windows) or ./run.sh (mac/linux). Leave blank to run
# fully offline (local-only).
SUPABASE_URL=
SUPABASE_ANON_KEY=
